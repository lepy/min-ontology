@prefix opa:     <https://w3id.org/opa#> .
@prefix min:     <https://w3id.org/min#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/opa/alignment/min> a owl:Ontology ;
    dcterms:title "OPA to MIN alignment"@en ;
    dcterms:description "Explicit class alignment between OPA categories and MIN foundational concepts."@en ;
    dcterms:created "2026-03-01"^^xsd:date ;
    owl:imports <https://w3id.org/opa> ;
    owl:imports <https://w3id.org/min> .

opa:Object rdfs:subClassOf min:Nexus .
opa:Process rdfs:subClassOf min:Nexus .
opa:Agent rdfs:subClassOf min:Nexus .
