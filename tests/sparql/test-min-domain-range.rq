PREFIX owl:  <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX min:  <https://w3id.org/min#>

ASK WHERE {
  FILTER NOT EXISTS {
    ?p a owl:ObjectProperty .
    FILTER NOT EXISTS { ?p rdfs:domain ?domain . }
  }

  FILTER NOT EXISTS {
    ?p a owl:ObjectProperty .
    FILTER(?p NOT IN (
      min:materialAspect,
      min:informationalAspect
    ))
    FILTER NOT EXISTS { ?p rdfs:range ?range . }
  }
}
