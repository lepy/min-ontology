PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX min: <https://w3id.org/min#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

ASK WHERE {
  # Nexus-internal disjointness: Object, Process, Data
  ?d1 a owl:AllDisjointClasses ;
      owl:members ?m1 .
  ?m1 rdf:first min:Object .

  # Forma-internal disjointness: Lex, Structura, Possibile, Norma, Institutio
  ?d2 a owl:AllDisjointClasses ;
      owl:members ?m2 .
  ?m2 rdf:first min:Lex .

  # Branch disjointness: Nexus, Forma
  ?d3 a owl:AllDisjointClasses ;
      owl:members ?m3 .
  ?m3 rdf:first min:Nexus .
  ?m3 rdf:rest/rdf:first min:Forma .
}
