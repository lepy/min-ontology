# =============================================================================
#   MIN — Material · Information · Nexus
#   TEIL X — METAVOKABULAR (Selbstbeschreibende Klassendokumentation)
#
#   Zweck:
#     Dieses Modul definiert die Annotation Properties, mit denen beliebige
#     Ontologie-Entitäten (Klassen, Properties, Individuen) strukturiert
#     dokumentiert werden — inklusive MIN selbst.
#
#   Entwurfsprinzipien:
#     1. Irreduzibilität — Jede Property deckt eine Dimension ab, die keine
#        andere Property abdecken kann.
#     2. Selbstbeschreibung — Das Vokabular dokumentiert sich mit sich selbst.
#     3. Minimalität — Keine Property, deren Fehlen tolerierbar wäre.
#     4. Universalität — Anwendbar auf Klassen, Properties und Individuen.
#
#   Dimensionen (7, irreduzibel):
#     I.   Intension        — Was ist es?           (definition, criterion)
#     II.  Extension         — Wie sieht es aus?     (usageExample)
#     III. Grenze            — Was ist es nicht?      (counterExample, distinguishedFrom)
#     IV.  Herkunft          — Woher kommt es?        (philosophicalBasis, normativeSource)
#     V.   Teleologie        — Warum existiert es?    (rationale)
#     VI.  Lebenszyklus      — In welchem Zustand?    (definedInVersion, status, replacedBy)
#     VII. Axiom-Transparenz — Warum diese Formalia?  (axiomRationale)
#
#   Vorbild:  IAO (Information Artifact Ontology) im OBO-Ökosystem,
#             aber MIN-nativ, schlanker und selbstbeschreibend.
#
#   Version:  1.0.0
#   Lizenz:   CC BY 4.0
# =============================================================================

@prefix min:     <https://w3id.org/min/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .


# =============================================================================
#   ONTOLOGIE-DEKLARATION
# =============================================================================

<https://w3id.org/min/meta> a owl:Ontology ;
    owl:versionIRI <https://w3id.org/min/meta/1.0.0> ;
    owl:versionInfo "1.0.0" ;
    owl:imports <https://w3id.org/min/3.3.0> ;
    dcterms:title "MIN Meta — Selbstbeschreibendes Dokumentationsvokabular"@de ;
    dcterms:title "MIN Meta — Self-Describing Documentation Vocabulary"@en ;
    dcterms:description """MIN Meta definiert die Annotation Properties, mit denen
    beliebige Ontologie-Entitäten (Klassen, Properties, Individuen) strukturiert
    dokumentiert werden — inklusive MIN selbst.
    11 Properties in 7 irreduziblen Dimensionen: Intension, Extension, Grenze,
    Herkunft, Teleologie, Lebenszyklus, Axiom-Transparenz."""@de ;
    dcterms:creator "Dr. Ingolf Lepenies" ;
    dcterms:created "2026-03-05"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:seeAlso <https://w3id.org/min> .


# =============================================================================
#   I. INTENSION — Was ist die Entität?
# =============================================================================

min:definition a owl:AnnotationProperty ;
    rdfs:label "Definition"@de ;
    rdfs:label "definition"@en ;
    rdfs:comment """Eine Satz-Definition der Entität.
    Präzise, nicht-zirkulär, genus-differentia wo möglich."""@de ;
    rdfs:range xsd:string ;
    # --- Selbstbeschreibung ---
    min:definition """Eine natürlichsprachliche Satz-Definition, die eine
    Ontologie-Entität so beschreibt, dass ein sachkundiger Leser sie ohne
    weitere Quellen eindeutig identifizieren kann."""@de ;
    min:criterion "Könnte ein sachkundiger Leser allein anhand dieses Satzes entscheiden, ob ein gegebenes Ding zur Klasse gehört oder nicht?"@de ;
    min:rationale """Ohne eine explizite Definition bleibt die Semantik
    einer Klasse implizit im Label und in der Axiomatik verborgen.
    Das genügt für Maschinen, nicht für Menschen."""@de ;
    min:distinguishedFrom "rdfs:comment — der informell, unstrukturiert und redundant sein darf. min:definition ist normativ und nicht-zirkulär."@de ;
    min:usageExample "min:Object min:definition \"Ein Ding, das kausal wirksam ist — es kann Wirkungen empfangen oder ausüben.\"@de ."@de ;
    min:usageExample "min:Typus min:definition \"Das Bündel von Bestimmungen, das eine Klasse von Nexus-Instanzen konstituiert. Typus bestimmt, ALS WAS ein Nexus zählt.\"@de ."@de ;
    min:definedInVersion "1.0.0" ;
    min:status "stable" .

min:criterion a owl:AnnotationProperty ;
    rdfs:label "Existenzkriterium"@de ;
    rdfs:label "criterion"@en ;
    rdfs:comment """Die Frage, die eine Instanz erfüllen muss,
    um zur Klasse zu gehören. In MIN typisch als Ja/Nein-Frage."""@de ;
    rdfs:range xsd:string ;
    # --- Selbstbeschreibung ---
    min:definition """Eine operationalisierbare Ja/Nein-Frage, deren Bejahung
    eine Entität als Instanz der annotierten Klasse qualifiziert."""@de ;
    min:criterion "Kann die Frage prinzipiell mit Ja oder Nein beantwortet werden, und trennt sie Instanzen zuverlässig von Nicht-Instanzen?"@de ;
    min:rationale """Eine Definition sagt, was etwas *ist*. Ein Kriterium
    sagt, wie man *entscheidet*. Beide sind irreduzibel: Eine gute
    Definition kann ein schlechtes Entscheidungsverfahren haben
    und umgekehrt."""@de ;
    min:distinguishedFrom "min:definition — die beschreibt, was die Klasse ist. min:criterion beschreibt, wie man Zugehörigkeit prüft."@de ;
    min:counterExample "\"Ist das Objekt wichtig?\" — zu vage, nicht operationalisierbar."@de ;
    min:usageExample "min:Process min:criterion \"Verbraucht oder transformiert die Entität Inputs zu Outputs über die Zeit?\"@de ."@de ;
    min:usageExample "min:Typus min:criterion \"Kann man fragen: Was für ein X ist das? — und liefert die Antwort eine Wesensbestimmung?\"@de ."@de ;
    min:definedInVersion "1.0.0" ;
    min:status "stable" .


# =============================================================================
#   II. EXTENSION — Wie sieht die Entität konkret aus?
# =============================================================================

min:usageExample a owl:AnnotationProperty ;
    rdfs:label "Verwendungsbeispiel"@de ;
    rdfs:label "usage example"@en ;
    rdfs:comment "Konkrete Instanz oder Nutzung der Entität."@de ;
    rdfs:range xsd:string ;
    # --- Selbstbeschreibung ---
    min:definition """Ein konkretes Beispiel — als natürlichsprachliche
    Beschreibung oder als Turtle-Fragment — das zeigt, wie die
    annotierte Entität in der Praxis instanziiert oder verwendet wird."""@de ;
    min:criterion "Zeigt das Beispiel eine korrekte, nicht-triviale Verwendung der Entität in einem realistischen Kontext?"@de ;
    min:rationale """Definitionen und Kriterien sind abstrakt. Beispiele
    verankern das Verständnis in konkreter Praxis und reduzieren
    Mehrdeutigkeit, die Definitionen allein nicht auflösen können."""@de ;
    min:distinguishedFrom "min:counterExample — das zeigt, was die Entität *nicht* ist. min:usageExample zeigt, was sie *ist*."@de ;
    min:counterExample "\"z.B. ein Auto\" — zu unspezifisch, kein Verwendungskontext sichtbar."@de ;
    min:usageExample "min:Agent min:usageExample \"ex:Operator_01 a min:Agent ; rdfs:label \\\"Prüfingenieur Müller\\\"@de .\"@de ."@de ;
    min:definedInVersion "1.0.0" ;
    min:status "stable" .


# =============================================================================
#   III. GRENZE — Was ist die Entität nicht?
# =============================================================================

min:counterExample a owl:AnnotationProperty ;
    rdfs:label "Gegenbeispiel"@de ;
    rdfs:label "counterexample"@en ;
    rdfs:comment """Eine Entität, die ähnlich scheint, aber nicht
    zur Klasse gehört — mit Begründung."""@de ;
    rdfs:range xsd:string ;
    # --- Selbstbeschreibung ---
    min:definition """Ein konkretes Beispiel einer Entität, die
    der annotierten Klasse nahezuliegen scheint, aber nach deren
    Kriterium nicht dazugehört — zusammen mit der Begründung,
    warum nicht."""@de ;
    min:criterion "Würde ein Nicht-Experte die genannte Entität plausibel der Klasse zuordnen, obwohl sie nicht dazugehört?"@de ;
    min:rationale """Definitionen und Kriterien allein lassen Grenzfälle
    offen. Gegenbeispiele machen die Grenze der Klasse sichtbar,
    besonders dort, wo Verwechslungsgefahr besteht."""@de ;
    min:distinguishedFrom "min:distinguishedFrom — das grenzt *Klassen* voneinander ab. min:counterExample nennt ein konkretes *Ding*, das nicht zur Klasse gehört."@de ;
    min:usageExample "min:Agent min:counterExample \"Eine CNC-Maschine ist kein Agent, da sie keine Handlungskompetenz besitzt, sondern Anweisungen ausführt. → min:Object.\"@de ."@de ;
    min:definedInVersion "1.0.0" ;
    min:status "stable" .

min:distinguishedFrom a owl:AnnotationProperty ;
    rdfs:label "Abgrenzung"@de ;
    rdfs:label "distinguished from"@en ;
    rdfs:comment """Abgrenzung zu einer verwandten Klasse.
    Mehrfach verwendbar für mehrere Abgrenzungen."""@de ;
    rdfs:range xsd:string ;
    # --- Selbstbeschreibung ---
    min:definition """Eine explizite Abgrenzung der annotierten Klasse
    gegenüber einer verwandten Klasse, die ein anderer Modellierer
    verwechseln oder zusammenlegen könnte."""@de ;
    min:criterion "Gibt es eine dokumentierte Verwechslungsgefahr zwischen den beiden Klassen, und macht die Abgrenzung den Unterschied operationalisierbar?"@de ;
    min:rationale """Ontologien wachsen durch mehrere Beitragende. Ohne
    explizite Abgrenzungen driften Klassengrenzen auseinander, weil
    jeder Modellierer eine eigene Intuition hat."""@de ;
    min:distinguishedFrom "min:counterExample — das nennt ein konkretes Ding. min:distinguishedFrom nennt eine *Klasse* und begründet die Trennung."@de ;
    min:usageExample "min:Data min:distinguishedFrom \"min:Object — Data ist kausal inert (kann kopiert, gelöscht werden ohne physische Wirkung). Object ist kausal wirksam.\"@de ."@de ;
    min:usageExample "min:Typus min:distinguishedFrom \"min:Norma — Norma BEWERTET (Rm SOLL ≥ 270 MPa). Typus KONSTITUIERT (DC04 IST das, was C ≤ 0.08% und Rm 270–350 MPa hat).\"@de ."@de ;
    min:definedInVersion "1.0.0" ;
    min:status "stable" .


# =============================================================================
#   IV. HERKUNFT — Woher kommt die Entität?
# =============================================================================

# min:philosophicalBasis — bereits in MIN definiert, wird hier nur
# selbstbeschrieben, nicht neu deklariert.
# Annahme: existiert als owl:AnnotationProperty im Hauptmodul.

min:normativeSource a owl:AnnotationProperty ;
    rdfs:label "Normative Quelle"@de ;
    rdfs:label "normative source"@en ;
    rdfs:comment """Standard, Spezifikation oder Fachquelle, auf der die
    Definition der annotierten Entität inhaltlich basiert."""@de ;
    rdfs:range xsd:string ;
    # --- Selbstbeschreibung ---
    min:definition """Ein Verweis auf einen publizierten Standard,
    eine Spezifikation oder eine anerkannte Fachquelle, deren
    inhaltliche Definition die Semantik der annotierten Entität
    begründet oder einschränkt."""@de ;
    min:criterion "Ist die genannte Quelle ein publiziertes, zitierfähiges Dokument, das die Definition der Entität inhaltlich stützt?"@de ;
    min:rationale """min:philosophicalBasis verweist auf die begriffliche
    Tradition (Aristoteles, Whitehead). Aber wenn eine Klasse aus
    DIN EN ISO 6892-1 abgeleitet ist, braucht man einen getrennten
    Verweis auf die *fachliche* Quelle. Philosophische Tradition ≠
    normative Referenz."""@de ;
    min:distinguishedFrom "min:philosophicalBasis — verweist auf philosophische Tradition und Begriffsgeschichte. min:normativeSource verweist auf technische oder wissenschaftliche Autoritätsquellen."@de ;
    min:distinguishedFrom "dcterms:source — ein generischer Dublin-Core-Verweis ohne die Einschränkung auf normative, definitionsstützende Quellen."@de ;
    min:usageExample "sdata:TensileTest min:normativeSource \"DIN EN ISO 6892-1:2019, Abschnitt 3.1\"@de ."@de ;
    min:usageExample "ex:DC04_typus min:normativeSource \"EN 10130:2006, Tabelle 3 — Chemische Zusammensetzung und mechanische Eigenschaften\"@de ."@de ;
    min:definedInVersion "1.0.0" ;
    min:status "stable" .


# =============================================================================
#   V. TELEOLOGIE — Warum existiert die Entität hier?
# =============================================================================

min:rationale a owl:AnnotationProperty ;
    rdfs:label "Entwurfsbegründung"@de ;
    rdfs:label "design rationale"@en ;
    rdfs:comment """Begründung, warum diese Entität in der Ontologie
    existiert — welches Modellierungsproblem sie löst."""@de ;
    rdfs:range xsd:string ;
    # --- Selbstbeschreibung ---
    min:definition """Eine natürlichsprachliche Begründung, die erklärt,
    welches konkrete Modellierungsproblem die annotierte Entität löst
    und warum keine bestehende Entität dieses Problem bereits abdeckt."""@de ;
    min:criterion "Benennt der Text ein konkretes Modellierungsproblem und erklärt, warum keine bestehende Entität es löst?"@de ;
    min:rationale """min:definition sagt *was*, min:philosophicalBasis sagt
    *woher der Begriff stammt* — aber keines beantwortet: 'Warum habt
    ihr das nicht einfach unter X subsumiert?' Ohne Rationale geht
    die Entwurfsentscheidung verloren, sobald der Autor nicht mehr
    verfügbar ist."""@de ;
    min:distinguishedFrom "min:definition — die beschreibt, was die Entität *ist*. min:rationale beschreibt, warum sie *sein muss*."@de ;
    min:distinguishedFrom "min:philosophicalBasis — die verortet den Begriff in einer Denktradition. min:rationale verortet ihn im Kontext der Ontologie-Architektur."@de ;
    min:counterExample "\"Weil es praktisch ist\" — keine Begründung, kein Modellierungsproblem benannt."@de ;
    min:usageExample "min:EnvironmentAgent min:rationale \"Natürliche Prozesse (Korrosion, Alterung) haben keinen intentionalen Agenten. Ohne EnvironmentAgent müsste man Agent-Instanzen für physikalische Gesetze anlegen, was die Semantik von Agent verwässert.\"@de ."@de ;
    min:usageExample "min:Typus min:rationale \"MIN v3.2 konnte einzelne Bestimmungen aussprechen, aber nicht sagen: Das ist ein DC04. Die Wesensbestimmung hatte keine ontologische Heimat. Workarounds (OWL-Klasse, SKOS-Konzept, Norma) waren alle unzureichend.\"@de ."@de ;
    min:definedInVersion "1.0.0" ;
    min:status "stable" .


# =============================================================================
#   VI. LEBENSZYKLUS — In welchem Zustand ist die Entität?
# =============================================================================

min:definedInVersion a owl:AnnotationProperty ;
    rdfs:label "Definiert in Version"@de ;
    rdfs:label "defined in version"@en ;
    rdfs:comment "Versionsnummer der Ontologie, in der diese Entität eingeführt wurde."@de ;
    rdfs:range xsd:string ;
    # --- Selbstbeschreibung ---
    min:definition """Die Versionsnummer (SemVer) der Ontologie, in der
    die annotierte Entität erstmals eingeführt wurde."""@de ;
    min:criterion "Ist der Wert eine gültige SemVer-Versionsnummer, und entspricht sie dem Release, in dem die Entität erstmals erschien?"@de ;
    min:rationale """In einer sich entwickelnden Ontologie müssen Nutzer
    nachvollziehen können, ab welcher Version eine Entität verfügbar
    ist — insbesondere für Abwärtskompatibilität und Migration."""@de ;
    min:distinguishedFrom "min:status — das den aktuellen Reifegrad beschreibt. min:definedInVersion beschreibt den historischen Einführungszeitpunkt."@de ;
    min:distinguishedFrom "owl:versionInfo — das die Ontologie als Ganzes versioniert. min:definedInVersion versioniert einzelne Entitäten."@de ;
    min:usageExample "min:normativeSource min:definedInVersion \"3.0.0\" ."@de ;
    min:definedInVersion "1.0.0" ;
    min:status "stable" .

min:status a owl:AnnotationProperty ;
    rdfs:label "Status"@de ;
    rdfs:label "status"@en ;
    rdfs:comment """Reifestatus der annotierten Entität.
    Erlaubte Werte: \"experimental\" | \"stable\" | \"deprecated\"."""@de ;
    rdfs:range xsd:string ;
    # --- Selbstbeschreibung ---
    min:definition """Der aktuelle Reifegrad der annotierten Entität im
    Lebenszyklus der Ontologie. Genau einer von drei Werten:
    'experimental' (kann sich ändern), 'stable' (festgeschrieben),
    'deprecated' (nicht mehr verwenden, siehe min:replacedBy)."""@de ;
    min:criterion "Ist der Wert exakt einer der drei erlaubten Strings: 'experimental', 'stable' oder 'deprecated'?"@de ;
    min:rationale """min:definedInVersion sagt, *wann* eine Entität
    eingeführt wurde, aber nicht, ob sie noch verwendet werden soll.
    Ohne expliziten Status weiß ein Nutzer nicht, ob er eine Klasse
    sicher einsetzen kann oder ob sie bald entfällt."""@de ;
    min:distinguishedFrom "min:definedInVersion — das einen historischen Zeitpunkt markiert. min:status beschreibt den *aktuellen* Zustand."@de ;
    min:distinguishedFrom "min:replacedBy — das den Nachfolger bei Deprecation nennt. min:status markiert nur den Zustand selbst."@de ;
    min:counterExample "\"beta\" — kein erlaubter Wert. Die Dreiteilung experimental/stable/deprecated ist erschöpfend."@de ;
    min:usageExample "min:definition min:status \"stable\" ."@de ;
    min:definedInVersion "1.0.0" ;
    min:status "stable" .

min:replacedBy a owl:AnnotationProperty ;
    rdfs:label "Ersetzt durch"@de ;
    rdfs:label "replaced by"@en ;
    rdfs:comment """Verweis auf die Nachfolger-Entität bei Deprecation.
    Nur sinnvoll in Kombination mit min:status \"deprecated\"."""@de ;
    rdfs:range rdfs:Resource ;
    # --- Selbstbeschreibung ---
    min:definition """Ein Verweis auf die Ontologie-Entität, die die
    annotierte (deprecated) Entität funktional ersetzt. Der Wert
    ist eine URI, kein String."""@de ;
    min:criterion "Ist die annotierte Entität deprecated, und bietet die referenzierte Entität tatsächlich einen funktionalen Ersatz?"@de ;
    min:rationale """Deprecation ohne Migrationspfad ist nutzlos. Nutzer
    müssen wissen, *wohin* sie migrieren sollen, nicht nur, dass
    sie migrieren müssen."""@de ;
    min:distinguishedFrom "min:status — das nur den Zustand 'deprecated' markiert. min:replacedBy nennt den konkreten Nachfolger."@de ;
    min:counterExample "min:replacedBy auf einer Entität mit min:status \"stable\" — semantisch widersprüchlich."@de ;
    min:usageExample """Hypothetisch: min:PhysicalObject min:status \"deprecated\" ;
    min:replacedBy min:Object ."""@de ;
    min:definedInVersion "1.0.0" ;
    min:status "stable" .


# =============================================================================
#   VII. AXIOM-TRANSPARENZ — Warum diese formalen Einschränkungen?
# =============================================================================

min:axiomRationale a owl:AnnotationProperty ;
    rdfs:label "Axiom-Begründung"@de ;
    rdfs:label "axiom rationale"@en ;
    rdfs:comment """Begründung für eine formale Restriktion (domain, range,
    cardinality, disjointness) in natürlicher Sprache."""@de ;
    rdfs:range xsd:string ;
    # --- Selbstbeschreibung ---
    min:definition """Eine natürlichsprachliche Begründung, die erklärt,
    warum eine bestimmte OWL-Restriktion (Domain, Range, Kardinalität,
    Disjunktheit) so gewählt wurde und welche Modellierungsalternative
    bewusst verworfen wurde."""@de ;
    min:criterion "Benennt der Text die spezifische Restriktion, begründet die Wahl und benennt mindestens eine verworfene Alternative?"@de ;
    min:rationale """OWL-Axiome sind maschinenlesbar, aber ihre
    Entwurfsentscheidungen sind es nicht. Die jüngste Korrektur der
    Process-Axiome in MIN (Öffnung für Data-Inputs neben Object-Inputs)
    zeigt: Ohne dokumentierte Begründung muss jeder Nachfolger die
    Designentscheidung neu rekonstruieren."""@de ;
    min:distinguishedFrom "min:rationale — das begründet, warum die *Entität* existiert. min:axiomRationale begründet, warum eine *formale Einschränkung* auf der Entität so gewählt wurde."@de ;
    min:counterExample "\"Domain ist Object, weil das sinnvoll ist.\" — keine Begründung, keine verworfene Alternative."@de ;
    min:usageExample """min:hasInput min:axiomRationale \"Range ist min:Entity (nicht nur min:Object),
    weil Prozesse sowohl physische Objekte als auch Daten konsumieren können.
    Die frühere Einschränkung auf min:Object wurde in v3.0.0 korrigiert,
    da sie FEM-Simulationen nicht abbilden konnte.\"@de ."""@de ;
    min:usageExample """min:typifies min:axiomRationale \"typifies ist subPropertyOf
    constrains, weil Typifizierung eine spezielle Form der Bestimmung ist.
    Verworfene Alternative: eigenständige Top-Level-Brückenrelation — aber
    Typifizierung IST Einschränkung (auf eine Wesensbestimmung).\"@de ."""@de ;
    min:definedInVersion "1.0.0" ;
    min:status "stable" .


# =============================================================================
#   DEMONSTRATION — min:Typus dokumentiert mit dem Metavokabular
#
#   Zeigt, wie alle 11 Properties zusammenwirken, um eine Klasse
#   vollständig zu dokumentieren. Die Annotationen hier ergänzen
#   die in MIN v3.3.0 bereits vorhandenen rdfs:comment, skos:example,
#   min:designRationale und min:philosophicalBasis.
# =============================================================================

min:Typus
    # I. Intension
    min:definition """Das Bündel von Bestimmungen, das eine Klasse von
    Nexus-Instanzen konstituiert. Typus bestimmt, ALS WAS ein Nexus
    zählt — nicht, was er hat (Property), nicht, was er soll (Norma),
    sondern, was er IST."""@de ;
    min:criterion """Kann man fragen: ‹Was für ein X ist das?› — und
    liefert die Antwort eine Wesensbestimmung (ein Bündel von
    Bestimmungen, das die Sorte/Art konstituiert)?"""@de ;

    # II. Extension
    min:usageExample """ex:DC04_typus a min:Typus ;
    rdfs:label \"DC04\"@de ;
    min:hasIdentifier \"DC04\" ;
    min:typifies ex:blech_042 ."""@de ;

    # III. Grenze
    min:counterExample """Ein SKOS-Konzept ‹DC04› in einem Thesaurus.
    Es klassifiziert terminologisch, aber es bestimmt nicht die
    Wesensform — es hat keine Verbindung zu Structura, Lex, Norma.
    → skos:Concept, nicht min:Typus."""@de ;
    min:distinguishedFrom """min:Norma — Norma BEWERTET (Soll). Typus
    KONSTITUIERT (Wesen). Norma: ‹Rm SOLL ≥ 270 MPa.› Typus:
    ‹DC04 IST das, was C ≤ 0.08% und Rm 270–350 MPa hat.›
    EN 10130 zurückgezogen → DC04 bleibt."""@de ;
    min:distinguishedFrom """min:Structura — Structura ist formal-rein
    (eine mathematische Struktur). Typus ist komposit — er BÜNDELT
    Structura, Norma, Lex und Properties zu einer
    Wesensbestimmung."""@de ;
    min:distinguishedFrom """min:Institutio — Institutio braucht laufende
    kollektive Anerkennung (ohne EZB kein Euro). Typus nicht —
    DC04 bleibt DC04, auch wenn das Normungsgremium aufgelöst
    wird."""@de ;
    min:distinguishedFrom """min:Lex — Lex ist universell und
    ausnahmslos. Typus ist kontingent — DC04 hätte andere
    Grenzwerte haben können."""@de ;

    # IV. Herkunft
    # min:philosophicalBasis — bereits in MIN v3.3.0 vorhanden
    #   (Aristoteles: Eidos, Quine: Natural Kinds, Putnam, Weber)
    min:normativeSource """Aristoteles: Metaphysik, Buch Z (Eidos als
    Wesensform). Quine: Natural Kinds (1969). Putnam: The Meaning
    of ‹Meaning› (1975). Weber: Objektive Möglichkeit und
    adäquate Verursachung (1906, Idealtyp)."""@de ;

    # V. Teleologie
    min:rationale """MIN v3.2 konnte einzelne Bestimmungen aussprechen
    (Norma: Rm ≥ 270 MPa; Structura: bcc-Gitter), aber nicht sagen:
    ‹Das ist ein DC04.› Die Wesensbestimmung — der Satz, den jeder
    Ingenieur täglich sagt — hatte keine ontologische Heimat.
    Workarounds waren unzureichend: OWL-Klasse (hat Klassen FÜR
    Typen, aber keinen Begriff VON Typus), SKOS-Konzept
    (klassifiziert ohne zu bestimmen), Norma (kodifiziert den
    Typus, IST nicht der Typus)."""@de ;

    # VI. Lebenszyklus
    min:definedInVersion "3.3.0" ;
    min:status "stable" ;

    # VII. Axiom-Transparenz
    min:axiomRationale """Typus ist disjunkt mit Lex, Structura, Possibile,
    Norma, Institutio. Begründung: Typus ist komposit (bündelt andere
    Forma-Kategorien), während jede andere Forma-Kategorie atomar ist.
    Verworfene Alternative: Typus als Subklasse von Norma — aber
    Norma bewertet, Typus konstituiert. Ein Typus kann Normen
    BÜNDELN, aber ein Typus IST keine Norma."""@de ;
    min:axiomRationale """min:typifies ist subPropertyOf min:constrains.
    Begründung: Typifizierung ist eine spezielle Form der
    Bestimmung — sie beschränkt den Nexus auf eine Wesensform.
    Verworfene Alternative: eigenständige Top-Level-Brückenrelation.
    Aber Typifizierung IST Einschränkung (auf eine Art), also
    gehört sie unter constrains."""@de .


# =============================================================================
#   VOLLSTÄNDIGKEITSNACHWEIS — Selbstbeschreibung des Metavokabulars
# =============================================================================
#
#   Jede der 11 Properties oben ist mit sich selbst und den anderen
#   Properties des Metavokabulars annotiert, wo anwendbar.
#   Das beweist:
#
#   (a) Ausdrucksstärke — das Vokabular kann alles beschreiben,
#       was es beschreiben soll, einschließlich sich selbst.
#
#   (b) Irreduzibilität — keine Property ist durch Kombination
#       der anderen ersetzbar (nachweisbar durch die paarweisen
#       distinguishedFrom-Annotationen).
#
#   (c) Vollständigkeit — es gibt keine Dokumentationsfrage, die
#       ein sachkundiger Leser stellen könnte und die keine der
#       11 Properties beantwortet:
#
#       „Was ist X?"                    → min:definition
#       „Wie entscheide ich?"           → min:criterion
#       „Wie sieht das konkret aus?"    → min:usageExample
#       „Was gehört nicht dazu?"        → min:counterExample
#       „Wie unterscheidet sich X von Y?" → min:distinguishedFrom
#       „Auf welcher Philosophie basiert X?" → min:philosophicalBasis
#       „Aus welchem Standard kommt X?" → min:normativeSource
#       „Warum gibt es X in MIN?"       → min:rationale
#       „Seit wann gibt es X?"          → min:definedInVersion
#       „Kann ich X noch verwenden?"    → min:status
#       „Was soll ich stattdessen nehmen?" → min:replacedBy
#       „Warum hat X diese Restriktion?" → min:axiomRationale
#
# =============================================================================
